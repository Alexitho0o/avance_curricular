    },
    "V_CATALOGO_SEM_ORI": {
      "descripcion": "SEM_ING_ORI ∈ {0, 1, 2}",
      "severidad": "BLOQUEANTE"
    },
    "V_COHERENCIA_FOR1": {
      "descripcion": "FOR=1 → ANIO_ING_ORI == ANIO_ING_ACT y SEM_ING_ORI == SEM_ING_ACT",
      "severidad": "BLOQUEANTE"
    },
    "V_COHERENCIA_FOR_NO1": {
      "descripcion": "FOR ∈ {2,3,4,11} → ANIO_ING_ACT > ANIO_ING_ORI (excepto ORI=1900)",
      "severidad": "WARNING"
    },
    "V_COHERENCIA_1900": {
      "descripcion": "ANIO_ING_ORI=1900 → SEM_ING_ORI=0",
